<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/viewRidesLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F9FF">

    <!-- Blue Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:background="@color/blue_primary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Available Rides"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Find nearby rides and book your seat"
            android:textColor="#B3E5FC"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Google Maps placeholder -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_margin="16dp"
        android:background="@drawable/card_rounded">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Google Maps Area"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_gravity="center" />

    </FrameLayout>

    <!-- Bottom available rides section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp">

        <TextView
            android:id="@+id/availableRidesTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nearby Rides"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:paddingBottom="8dp" />

        <ScrollView
            android:id="@+id/ridesScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/ridesListLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Ride Item 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_rounded"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="UiTM Puncak Perdana → Shah Alam"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Departure: 5:30 PM"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Available Seats: 3"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:layout_marginTop="2dp" />

                    <Button
                        android:id="@+id/bookBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Book Ride"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/blue_primary"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <!-- Ride Item 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_rounded"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Subang → UiTM Puncak Perdana"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Departure: 8:00 AM"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Available Seats: 2"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:layout_marginTop="2dp" />

                    <Button
                        android:id="@+id/bookBtn2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Book Ride"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/blue_primary"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</LinearLayout>