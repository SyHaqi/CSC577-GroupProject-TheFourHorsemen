<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9FF">

    <LinearLayout
        android:id="@+id/bookRideLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Blue Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:background="@color/blue_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/bookRideTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Book Ride"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm your ride details before booking"
                android:textColor="#B3E5FC"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ride Details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/rideDetailsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_rounded"
                android:padding="16dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:id="@+id/driverNameTextViewID"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/originTextViewID"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/destinationTextViewID"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/departureTimeTextViewID"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/availableSeatsTextViewID"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#1A1A1A" />

                <Button
                    android:id="@+id/btnViewMap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View on Map"
                    android:backgroundTint="@color/blue_primary"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Booking Details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/bookingDetailsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_rounded"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/passengerNameTextViewID"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="16dp" />

                <!-- Seat Selector -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Number of Seats"
                    android:textSize="15sp"
                    android:textColor="#555555"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/decreaseSeatButtonID"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="−"
                        android:textSize="20sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/blue_primary"
                        android:padding="0dp" />

                    <TextView
                        android:id="@+id/seatCountTextViewID"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/increaseSeatButtonID"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="+"
                        android:textSize="20sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/blue_primary"
                        android:padding="0dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/seatLimitHintTextViewID"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <Button
                android:id="@+id/confirmBookingButtonID"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm Booking"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/blue_primary"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/cancelBookingButtonID"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="@color/blue_primary"
                android:backgroundTint="#E3F2FD" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>